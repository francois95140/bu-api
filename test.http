Authorization: Bearer {{tokenAdmin}}
Content-Type: {{contentType}}

{
  "firstName": "Lucas",
  "lastName": "Bernard",
  "email": "etudiant@univ.fr",
  "password": "password123",
  "category": "STUDENT"
}

