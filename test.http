### ============================================================
### VARIABLES — IDs fixes injectés par le DatabaseSeeder
### ============================================================

@base = http://localhost:8080
@contentType = application/json

### Comptes (mot de passe : password123)
### admin@univ.fr | bibliothecaire@univ.fr | etudiant@univ.fr | etudiant2@univ.fr | enseignant@univ.fr

### IDs utilisateurs
@adminId     = u-admin-001
@librarianId = u-lib-001
@student1Id  = u-stu-001
@student2Id  = u-stu-002
@teacherId   = u-tea-001

### IDs ouvrages
@work1Id = w-001
@work2Id = w-002
@work3Id = w-003
@work4Id = w-004

### IDs exemplaires
@copy1Id = c-001
@copy2Id = c-002
@copy3Id = c-003
@copy5Id = c-005
@copy7Id = c-007

### IDs prêts
@loan1Id = l-001
@loan2Id = l-002
@loan5Id = l-005
@loan6Id = l-006

### IDs réservations
@hold1Id = h-001
@hold2Id = h-002

### IDs pénalités
@penalty1Id = p-001
@penalty2Id = p-002

